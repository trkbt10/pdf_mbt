{
  "name": "@trkbt10/pdf-wasm-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint src --max-warnings=0",
    "test": "npm run lint && node --test \"test/*.test.mjs\" \"test/browser/*.test.mjs\"",
    "test:browser": "node --test \"test/browser/*.test.mjs\"",
