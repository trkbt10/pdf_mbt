///|
fn jpx_filter_dict() -> @objects.PdfDictionary {
  let dict : @objects.PdfDictionary = Map::new()
  dict[@objects.PdfName::new(b"Filter")] = @objects.PdfObject::Name(
    @objects.PdfName::new(b"JPXDecode"),
  )
  dict
}

///|
test "decode_jpx_image exposes JPEG 2000 metadata and sample bytes" {
  let image = decode_jpx_image(jpx_test_codestream())
  assert_eq(image.width, 128)
  assert_eq(image.height, 1)
  assert_eq(image.num_components, 1)
  assert_eq(image.bits_per_component, 8)
  assert_eq(image.is_signed, false)
  assert_eq(image.data, jpx_expected_samples())
}

///|
test "decode_stream_bytes decodes JPXDecode sample bytes" {
  let decoded = decode_stream_bytes(jpx_filter_dict(), jpx_test_codestream())
  assert_eq(decoded, jpx_expected_samples())
}

///|
test "decode_stream_bytes maps JPXDecode failures to filter decode errors" {
  let decoded : Result[Bytes, PdfFilterError] = try? decode_stream_bytes(
    jpx_filter_dict(),
    b"",
  )
  match decoded {
    Err(DecodeError(filter_name, reason)) => {
      assert_eq(filter_name, "JPXDecode")
      assert_eq(reason.length() > 0, true)
    }
    _ => fail("expected JPXDecode decode failure")
  }
}
