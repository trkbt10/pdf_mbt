    b"08> <ff09> 8077\n<ff1a> <ff1f> 8081\n<ff5b> <ff5d> 8090\nendcidrange\n\nendcmap\nCMapName currentdict /CMap defineresource pop\nend\nend\n\n%%EndResource\n%%EOF\n",
  ])
}

///|
/// Lookup a predefined CMap by its PostScript name.
/// Returns the original Adobe CMap source bytes, ready to feed into
/// `parse_decoded_cmap`. Unknown names return None.
pub fn predefined_cmap_lookup(name : String) -> Bytes? {
  if name == "H" { return Some(predefined_cmap_h()) }
  if name == "V" { return Some(predefined_cmap_v()) }
  if name == "EUC-H" { return Some(predefined_cmap_euc_h()) }
  if name == "EUC-V" { return Some(predefined_cmap_euc_v()) }
  if name == "83pv-RKSJ-H" { return Some(predefined_cmap_83pv_rksj_h()) }
  if name == "90ms-RKSJ-H" { return Some(predefined_cmap_90ms_rksj_h()) }
  if name == "90ms-RKSJ-V" { return Some(predefined_cmap_90ms_rksj_v()) }
  if name == "90msp-RKSJ-H" { return Some(predefined_cmap_90msp_rksj_h()) }
  if name == "90msp-RKSJ-V" { return Some(predefined_cmap_90msp_rksj_v()) }
  if name == "90pv-RKSJ-H" { return Some(predefined_cmap_90pv_rksj_h()) }
  if name == "Add-RKSJ-H" { return Some(predefined_cmap_add_rksj_h()) }
  if name == "Add-RKSJ-V" { return Some(predefined_cmap_add_rksj_v()) }
  if name == "Ext-RKSJ-H" { return Some(predefined_cmap_ext_rksj_h()) }
  if name == "Ext-RKSJ-V" { return Some(predefined_cmap_ext_rksj_v()) }
  if name == "UniJIS-UCS2-H" { return Some(predefined_cmap_unijis_ucs2_h()) }
  if name == "UniJIS-UCS2-V" { return Some(predefined_cmap_unijis_ucs2_v()) }
  if name == "UniJIS-UCS2-HW-H" { return Some(predefined_cmap_unijis_ucs2_hw_h()) }
  if name == "UniJIS-UCS2-HW-V" { return Some(predefined_cmap_unijis_ucs2_hw_v()) }
  if name == "UniJIS-UTF16-H" { return Some(predefined_cmap_unijis_utf16_h()) }
  if name == "UniJIS-UTF16-V" { return Some(predefined_cmap_unijis_utf16_v()) }
  if name == "GB-EUC-H" { return Some(predefined_cmap_gb_euc_h()) }
  if name == "GB-EUC-V" { return Some(predefined_cmap_gb_euc_v()) }
  if name == "GBpc-EUC-H" { return Some(predefined_cmap_gbpc_euc_h()) }
  if name == "GBpc-EUC-V" { return Some(predefined_cmap_gbpc_euc_v()) }
  if name == "GBK-EUC-H" { return Some(predefined_cmap_gbk_euc_h()) }
  if name == "GBK-EUC-V" { return Some(predefined_cmap_gbk_euc_v()) }
  if name == "GBKp-EUC-H" { return Some(predefined_cmap_gbkp_euc_h()) }
  if name == "GBKp-EUC-V" { return Some(predefined_cmap_gbkp_euc_v()) }
  if name == "GBK2K-H" { return Some(predefined_cmap_gbk2k_h()) }
  if name == "GBK2K-V" { return Some(predefined_cmap_gbk2k_v()) }
  if name == "UniGB-UCS2-H" { return Some(predefined_cmap_unigb_ucs2_h()) }
  if name == "UniGB-UCS2-V" { return Some(predefined_cmap_unigb_ucs2_v()) }
  if name == "UniGB-UTF16-H" { return Some(predefined_cmap_unigb_utf16_h()) }
  if name == "UniGB-UTF16-V" { return Some(predefined_cmap_unigb_utf16_v()) }
  if name == "B5pc-H" { return Some(predefined_cmap_b5pc_h()) }
  if name == "B5pc-V" { return Some(predefined_cmap_b5pc_v()) }
