///|
/// Predefined CMap byte tables generated from Adobe's official cmap-resources
/// repository (https://github.com/adobe-type-tools/cmap-resources). Adobe
/// publishes these as PostScript CMap source. The MoonBit cmap_parser already
/// understands the same syntax used by ToUnicode CMaps embedded in PDFs, so
/// we keep the original bytes verbatim and parse on first request.
///
/// Generated by tools/generate_predefined_cmaps.py — do not edit by hand.
///
/// MoonBit's parser rejects byte string literals beyond a size threshold
/// (error 4139), so each CMap is split into ~240-byte literals collected
/// into an Array and concatenated by `concat_bytes_chunks` at call time.

///|
fn concat_bytes_chunks(chunks : Array[Bytes]) -> Bytes {
  let mut total = 0
  for chunk in chunks {
    total = total + chunk.length()
  }
  let buf = FixedArray::make(total, b'\x00')
  let mut cursor = 0
  for chunk in chunks {
    for i in 0..<chunk.length() {
      buf[cursor + i] = chunk[i]
    }
    cursor = cursor + chunk.length()
  }
  let _ = cursor
  Bytes::from_fixedarray(buf)
}

